rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow create: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.uid == userId &&
        request.resource.data.plan == 'demo' &&
        request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'plan', 'createdAt']);
      allow update: if request.auth != null &&
        request.auth.uid == userId &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'email', 'updatedAt']);
      allow delete: if false;
    }

    match /patients/{patientId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      match /evolutions/{evolutionId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;

        match /revisions/{revisionId} {
          allow read, create: if request.auth != null &&
            get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
          allow update, delete: if false;
        }
      }

      match /anamnesis/{anamnesisId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
      }

      match /progressAnalyses/{analysisId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
      }

      match /evolutionDrafts/{draftId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
      }

      match /therapeuticPlan/{planId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
      }

      match /documents/{documentId} {
        allow read, write: if request.auth != null &&
          get(/databases/$(database)/documents/patients/$(patientId)).data.userId == request.auth.uid;
      }
    }

    match /schedules/{scheduleId} {
      allow read, delete: if request.auth != null && resource.data.userId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null &&
        resource.data.userId == request.auth.uid &&
        request.resource.data.userId == request.auth.uid;

      match /statusHistory/{historyId} {
        allow read, create: if request.auth != null &&
          get(/databases/$(database)/documents/schedules/$(scheduleId)).data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    // Criados e consultados exclusivamente pelo backend autenticado. O cliente
    // nunca pode alterar ou apagar a trilha de auditoria.
    match /auditLogs/{eventId} {
      allow read, create, update, delete: if false;
    }

    // Dados de cobrança, cotas e demais coleções só podem ser acessados pelo backend.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
