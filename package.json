    "test:watch": "vitest",
    "preview": "vite preview"
  },
  "dependencies": {
    "firebase": "^12.15.0",
    "firebase-admin": "^13.5.0",
    "pdfkit": "^0.19.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hot-toast": "^2.6.0",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "^10.5.2",
    "firebase-tools": "^15.23.0",
    "oxlint": "^1.71.0",
    "postcss": "^8.5.16",
    "tailwindcss": "^3.4.13",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
