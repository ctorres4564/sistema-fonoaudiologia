{
  "name": "sistema-fonoaudiologia",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "oxlint",
    "test": "vitest run --exclude tests/firestore.rules.test.js",
    "test:rules": "firebase emulators:exec --only firestore --project demo-fonoflow \"npm run test:rules:unit\"",
